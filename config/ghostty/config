# theme
theme = dark:Flexoki Dark,light:Flexoki Light

# font
font-family = "Berkeley Mono"
font-family = "Symbols Nerd Font Mono"
window-title-font-family = "Berkeley Mono"
font-size = 16

cursor-style = block
adjust-cell-height = 35%
window-padding-balance = true
window-save-state = always

# clipboard
clipboard-read = allow
clipboard-write = allow

# macos
mouse-hide-while-typing = true
mouse-scroll-multiplier = 2

# macos icon
macos-icon = custom-style
macos-icon-frame = beige
macos-icon-ghost-color = yellow
macos-icon-screen-color = green

# keybinds
keybind = global:cmd+alt+enter=toggle_quick_terminal
keybind = shift+enter=text:\x1b\r

#cmux
scrollback-limit = 50000

unfocused-split-opacity = 0.75

split-divider-color = #3e4451

# working-directory = ~/Code